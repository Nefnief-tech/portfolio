{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        { "src": "package.json", "dest": "package.json" },
        { "src": "bun.lock", "dest": "bun.lock" },
        { "cmd": "bun install", "customName": "Install dependencies" },
        { "path": "node_modules/.bin" }
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        { "src": ".", "dest": "." },
        { "cmd": "bun run build", "customName": "Build application" }
      ],
      "variables": {
        "NODE_ENV": "production"
      }
    }
  },
  "caches": {
    "bun": {
      "path": "/root/.bun/install/cache"
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "packages:mise",
        "include": ["/mise/shims", "/mise/installs"]
      },
      {
        "step": "build",
        "include": ["dist", "node_modules", "package.json"]
      }
    ],
    "startCommand": "node node_modules/vinext/dist/cli.js start",
    "paths": ["/mise/shims"],
    "variables": {
      "NODE_ENV": "production",
      "PORT": "3000"
    }
  }
}
