{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": ["bun install"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["bun run build"],
      "variables": {
        "NODE_ENV": "production"
      }
    }
  },
  "deploy": {
    "startCommand": "bun run start",
    "variables": {
      "NODE_ENV": "production",
      "PORT": "3000"
    }
  }
}
